---
interface Props {
  title: string;
  description?: string;
  lang?: string;
}
const { title, description = 'Local observability for your AI agents. Tokens, cost, latency, and full conversation replay — on your machine.', lang = 'en' } = Astro.props;
---
<!DOCTYPE html>
<html lang={lang}>
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description" content={description} />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <title>{title}</title>
  <script is:inline>
  (function() {
    var s = localStorage.getItem('tma1-theme');
    var t = (s === 'light' || s === 'dark') ? s :
      window.matchMedia('(prefers-color-scheme: light)').matches ? 'light' : 'dark';
    document.documentElement.setAttribute('data-theme', t);
  })();
  </script>
  <script is:inline>
  (function() {
    if (localStorage.getItem('tma1-locale')) return;
    var lang = (navigator.language || '').toLowerCase();
    var path = location.pathname;
    if (path !== '/' && path !== '/index.html') return;
    if (lang.startsWith('zh')) location.replace('/zh/');
    else if (lang.startsWith('es')) location.replace('/es/');
  })();
  </script>
</head>
<body>
  <slot />
</body>
</html>
