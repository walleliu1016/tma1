<script is:inline>
(function() {
  // Theme toggle
  function setTheme(choice) {
    var t;
    if (choice === 'system') {
      localStorage.removeItem('tma1-theme');
      t = window.matchMedia('(prefers-color-scheme: light)').matches ? 'light' : 'dark';
    } else {
      localStorage.setItem('tma1-theme', choice);
      t = choice;
    }
    document.documentElement.setAttribute('data-theme', t);
    document.querySelectorAll('.theme-img').forEach(function(img) {
      var src = t === 'light' ? img.dataset.lightSrc : img.dataset.darkSrc;
      if (src) img.src = src;
    });
    markActiveTheme(choice);
  }

  function markActiveTheme(choice) {
    document.querySelectorAll('[data-theme-value]').forEach(function(btn) {
      btn.classList.toggle('active', btn.getAttribute('data-theme-value') === choice);
    });
  }

  // Apply initial theme images
  var initTheme = localStorage.getItem('tma1-theme') || 'system';
  var resolved = initTheme === 'system'
    ? (window.matchMedia('(prefers-color-scheme: light)').matches ? 'light' : 'dark')
    : initTheme;
  document.querySelectorAll('.theme-img').forEach(function(img) {
    var src = resolved === 'light' ? img.dataset.lightSrc : img.dataset.darkSrc;
    if (src) img.src = src;
  });

  // Mark initial active theme
  markActiveTheme(initTheme);

  // Theme button clicks
  document.querySelectorAll('[data-theme-value]').forEach(function(btn) {
    btn.addEventListener('click', function() {
      setTheme(this.getAttribute('data-theme-value'));
      this.closest('details').removeAttribute('open');
    });
  });

  // System theme change listener
  window.matchMedia('(prefers-color-scheme: light)').addEventListener('change', function() {
    if (!localStorage.getItem('tma1-theme')) setTheme('system');
  });

  // Language selection - store preference
  document.querySelectorAll('[data-locale]').forEach(function(a) {
    a.addEventListener('click', function() {
      localStorage.setItem('tma1-locale', this.getAttribute('data-locale'));
    });
  });

  // Close dropdowns when clicking outside
  document.addEventListener('click', function(e) {
    document.querySelectorAll('details.dropdown').forEach(function(d) {
      if (!d.contains(e.target)) d.removeAttribute('open');
    });
  });

  // Typing effect for hero hook
  var hookText = document.querySelector('.hook-text');
  if (hookText) {
    var full = hookText.getAttribute('data-text') || '';
    if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
      hookText.textContent = full;
    } else {
      var i = 0;
      var cursor = document.querySelector('.hook-cursor');
      setTimeout(function() { var id = setInterval(function() {
        hookText.textContent = full.slice(0, ++i);
        if (i >= full.length) {
          clearInterval(id);
          if (cursor) setTimeout(function() { cursor.style.opacity = '0'; cursor.style.transition = 'opacity 1s'; }, 2000);
        }
      }, 70); }, 1000);
    }
  }
})();
</script>
